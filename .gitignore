# Whirlpool VST3 Plugin - Git Ignore Rules
# ===========================================
# This file specifies patterns for files and directories that should be ignored by Git.
# Tailored for JUCE-based audio plugin development with cross-platform support.

# ==========================================
# JUCE Framework & Build System
# ==========================================

# JUCE Builds directory (platform-specific IDE project files and binaries)
Builds/
!Builds/.gitkeep

# JUCE Binary Data (auto-generated)
JuceLibraryCode/
BinaryData.*

# Projucer backup files
*.jucer.bak
*.jucer~

# JUCE module cache
juce_modules/

# ==========================================
# Platform-Specific Build Artifacts
# ==========================================

# Windows
# --------
# Visual Studio
*.vcxproj.user
*.vcxproj.filters
*.VC.db
*.VC.VC.opendb
*.sln.docstates
.vs/
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/

# Visual Studio Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# Windows System Files
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# macOS
# -----
# Xcode
*.xcodeproj/*
!*.xcodeproj/project.pbxproj
!*.xcodeproj/xcshareddata/
!*.xcodeproj/project.xcworkspace/
*.xcworkspace/*
!*.xcworkspace/contents.xcworkspacedata
!*.xcworkspace/xcshareddata/

# Xcode Build Products
build/
DerivedData/

# Xcode User State
*.xcuserstate
*.xcuserdatad

# macOS System Files
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.AppleDB
.AppleDesktop

# Linux
# -----
# Make build files
*.o
*.a
*.so
*.dylib
*.dll
Makefile.Debug
Makefile.Release

# Code::Blocks
*.cbp
*.layout
*.depend

# ==========================================
# Audio Plugin Specific
# ==========================================

# Plugin Binaries
*.vst3
*.vst
*.au
*.aax
*.component
*.dll
*.dylib
*.so

# Audio Plugin Validation Reports
*.txt
validation_report_*

# Plugin Host Projects (for testing)
TestHost/
PluginHost/

# Audio Files (for testing - usually too large for git)
*.wav
*.aif
*.aiff
*.mp3
*.flac
*.ogg
!docs/audio/*  # Allow small demo files in docs

# ==========================================
# IDE and Editor Files
# ==========================================

# IntelliJ/CLion
.idea/
*.iml
*.ipr
*.iws

# Eclipse
.metadata
bin/
tmp/
*.tmp
*.bak
*.swp
*~.nib
local.properties
.settings/
.loadpath
.recommenders

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp
.\#*

# Vim
*.swp
*.swo
*~
.vimrc.local

# Sublime Text
*.sublime-workspace
*.sublime-project

# Atom
.atom/

# ==========================================
# Documentation Build
# ==========================================

# Generated documentation
docs/_build/
docs/html/
docs/latex/
site/

# Doxygen output
Doxyfile.bak
html/
latex/

# ==========================================
# Package Managers & Dependencies
# ==========================================

# Node.js (if using for build tools)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn-integrity

# Python (if using for scripts)
__pycache__/
*.py[cod]
*$py.class
venv/
env/
.env

# ==========================================
# Version Control & Git
# ==========================================

# Git patches and merges
*.orig
*.rej
*.patch
.git/
.gitattributes.local

# GitHub Desktop
.github/
!.github/workflows/
!.github/ISSUE_TEMPLATE/
!.github/PULL_REQUEST_TEMPLATE.md

# ==========================================
# System and Temporary Files
# ==========================================

# Temporary files
*.tmp
*.temp
*.log
*.pid
*.seed
*.pid.lock

# Cache files
.cache/
*.cache

# Backup files
*.backup
*.bak
*.old
*~

# Compressed files (usually build artifacts)
*.7z
*.dmg
*.gz
*.iso
*.jar
*.rar
*.tar
*.zip

# ==========================================
# Profiling and Analysis
# ==========================================

# Performance profiling
*.prof
*.trace
*.perf
callgrind.out.*
massif.out.*

# Memory leak detection
*.memcheck
*.valgrind

# Code coverage
*.gcov
*.gcno
*.gcda
coverage/
*.coverage

# ==========================================
# CI/CD and Deployment
# ==========================================

# Build artifacts from CI
artifacts/
releases/
dist/

# Deployment keys and certificates
*.key
*.cert
*.p12
*.mobileprovision

# Environment configuration
.env.local
.env.development.local
.env.test.local
.env.production.local

# ==========================================
# Custom Project Files
# ==========================================

# User-specific settings
user_settings/
local_config/

# Test outputs
test_results/
test_output/

# Documentation drafts
drafts/
notes/
*.draft.md

# Asset sources (if very large)
# assets/raw/
# textures/source/

# ==========================================
# Allow Important Files
# ==========================================

# Force include important files that might match patterns above
!README.md
!LICENSE
!CHANGELOG.md
!CONTRIBUTING.md
!.gitignore
!.gitattributes

# Allow certain build scripts
!build.sh
!build.bat
!CMakeLists.txt

# Allow project configuration
!*.jucer
!projucer_settings.xml

# ==========================================
# Platform-Specific Exceptions
# ==========================================

# Allow certain Windows files if needed
# !some_windows_file.dll

# Allow certain macOS files if needed  
# !some_mac_file.dylib

# Allow certain Linux files if needed
# !some_linux_file.so

# ==========================================
# End of .gitignore
# ==========================================

# Note: This .gitignore is comprehensive but can be customized based on your specific workflow.
# Remove or comment out any rules that don't apply to your development setup.